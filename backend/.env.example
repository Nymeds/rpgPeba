# URL do banco usado pelo Prisma.
# Para desenvolvimento local com SQLite:
DATABASE_URL="file:./dev.db"

# Porta onde sobe o backend (HTTP + Socket.IO).
PORT=3000

# Segredo para assinar/validar JWT.
# Troque por uma string forte em ambiente real.
JWT_SECRET="troque-por-um-segredo-forte-com-pelo-menos-16-chars"

# Segredo dedicado para criptografia das mensagens de chat no banco.
# Se remover, o backend cai no fallback do JWT_SECRET.
CHAT_CRYPTO_SECRET="troque-por-um-segredo-forte-para-chat"

# Lista de origens permitidas no CORS, separadas por virgula.
# Inclua aqui TODAS as URLs que vao abrir o frontend:
# - localhost
# - IP da sua LAN (192.168.x.x ou 10.x.x.x)
# - IP virtual da Radmin/Hamachi (26.x.x.x), se for jogar remoto
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.8:5173,http://26.193.222.75:5173"
